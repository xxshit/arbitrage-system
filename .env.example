# MySQL is optional for the first local launch. Without these settings, SQLite is used.
DATABASE_URL=mysql+pymysql://root:your_password@127.0.0.1:3306/arbitrage_hub?charset=utf8mb4
SECRET_KEY=change-this-before-production
LARK_DAILY_TREND_WEBHOOK=https://open.larksuite.com/open-apis/bot/v2/hook/your-webhook-token
LARK_THOUGHT_ANALYSIS_WEBHOOK=https://open.larksuite.com/open-apis/bot/v2/hook/your-thought-analysis-webhook-token
